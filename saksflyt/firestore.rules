rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Sjekker at brukeren er logget inn.
    function signedIn() {
      return request.auth != null;
    }

    // Henter teamet som saken tilhører.
    function getTeam(teamId) {
      return get(
        /databases/$(database)/documents/teams/$(teamId)
      ).data;
    }

    function isOwner(teamId) {
      return signedIn()
        && getTeam(teamId).ownerId == request.auth.uid;
    }

    function isVerified(teamId) {
      return signedIn()
        && getTeam(teamId).verified[request.auth.uid] == true;
    }

    function hasCaseRole(teamId) {
      return getTeam(teamId).roles[request.auth.uid] == 'admin'
        || getTeam(teamId).roles[request.auth.uid] == 'member';
    }

    // Eier har alltid tilgang. Andre må være verifisert
    // og ha rollen admin eller medlem.
    function canReadCases(teamId) {
      return isOwner(teamId)
        || (isVerified(teamId) && hasCaseRole(teamId));
    }

    function isAdmin(teamId) {
      return isVerified(teamId)
        && getTeam(teamId).roles[request.auth.uid] == 'admin';
    }

    match /teams/{teamId} {

      // Dette trengs for å finne team med invitasjonskode.
      allow read: if signedIn();

      // Den som lager teamet blir eier og verifisert.
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.members == [request.auth.uid]
        && request.resource.data.roles[request.auth.uid] == 'owner'
        && request.resource.data.verified[request.auth.uid] == true;

      // Eier kan endre teamet, men kan ikke bytte ownerId.
      allow update: if signedIn()
        && request.resource.data.ownerId == resource.data.ownerId
        && (
          resource.data.ownerId == request.auth.uid
          || joiningAsGuest()
          || addingOwnEmail()
        );

      allow delete: if isOwner(teamId);

      match /cases/{caseId} {

        // Skjemaet for nye saker er offentlig.
        allow create: if true;

        // Gjester og brukere som ikke er verifisert stoppes her.
        allow read, update: if canReadCases(teamId);

        // Bare eier og admin kan slette saker.
        allow delete: if isOwner(teamId) || isAdmin(teamId);
      }
    }

    // En bruker med invitasjonskode kan bare legge til seg selv.
    // Nye brukere får alltid gjesterolle og verified = false.
    function joiningAsGuest() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['members', 'roles', 'verified', 'memberEmails'])
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.members.size()
          == resource.data.members.size() + 1
        && request.auth.uid in request.resource.data.members
        && !(request.auth.uid in resource.data.members)
        && request.resource.data.roles
          .diff(resource.data.get('roles', {}))
          .affectedKeys().hasOnly([request.auth.uid])
        && request.resource.data.roles[request.auth.uid] == 'guest'
        && request.resource.data.verified
          .diff(resource.data.get('verified', {}))
          .affectedKeys().hasOnly([request.auth.uid])
        && request.resource.data.verified[request.auth.uid] == false
        && request.resource.data.memberEmails
          .diff(resource.data.get('memberEmails', {}))
          .affectedKeys().hasOnly([request.auth.uid]);
    }

    // Eldre team mangler noen ganger e-post.
    // Et medlem får bare lagre sin egen e-post.
    function addingOwnEmail() {
      return request.auth.uid in resource.data.members
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['memberEmails'])
        && request.resource.data.memberEmails
          .diff(resource.data.get('memberEmails', {}))
          .affectedKeys().hasOnly([request.auth.uid])
        && request.resource.data.memberEmails[request.auth.uid]
          == request.auth.token.email;
    }
  }
}
